# DB Explorer — backend env (local dev)
#
# Copy to app/.env (the FastAPI process loads this on startup via python-dotenv).

# Free-form label shown in the UI header + status bar.
APP_ENV=LOCAL

# MySQL connection — fill in for your target database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Or use a one-line connection string instead of the above:
# MYSQL_CONN_STR=mysql://user:pass@host:3306/dbname

# Destructive ops feature flag — off by default. Set to "true" / "1" / "yes"
# to expose DROP TABLE and DELETE FROM in the API (the UI still demands user
# confirmation via a warning modal).
# DESTRUCTIVE_OPS_ENABLED=false
